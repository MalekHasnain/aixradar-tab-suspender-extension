{
  "manifest_version": 3,
  "name": "Tab Suspender Pro",
  "version": "1.0.0",
  "description": "Auto-suspend inactive tabs to save memory. Configurable timeout, site whitelist, and manual controls.",
  "permissions": [
    "storage",
    "tabs",
    "alarms"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tab Suspender Pro",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "suspended.html"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}